<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/widget_camera_button"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/widget_button_background"
        android:clickable="true"
        android:contentDescription="@string/widget_open_camera"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:contentDescription="@null"
            android:src="@android:drawable/ic_menu_camera" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_status_button"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_primary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1840"
            android:textColor="#F8FAFA"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_secondary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="kcal left"
            android:textColor="#C7D6D7"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_background_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/widget_button_background"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp"
            android:text="1 background item"
            android:textColor="#182226"
            android:textSize="9sp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>

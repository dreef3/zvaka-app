<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/widget_camera_button"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:background="@drawable/widget_button_background"
        android:clickable="true"
        android:contentDescription="@string/widget_open_camera"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_widget_camera" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/widget_log_label"
            android:textColor="#182226"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_status_button"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_primary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1840"
            android:textColor="#F8FAFA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_secondary_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="kcal left"
            android:textColor="#A0B8BB"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_background_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/widget_badge_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="1 in bg"
            android:textColor="#C7D6D7"
            android:textSize="9sp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
